ne2019-DET-test-dev/labels\"\n\n\nWORKING_DIR = \"/kaggle/working/visdrone_yolo\"\n\nos.makedirs(WORKING_DIR, exist_ok=True)\n\nprint(\"Dataset paths are ready\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Create YOLO directory structure","metadata":{}},{"cell_type":"code","source":"YOLO_DATASET = f\"{WORKING_DIR}/visdrone_human_car\"\n\ndirs = [\n    f\"{YOLO_DATASET}/images/train\",\n    f\"{YOLO_DATASET}/images/val\",\n    f\"{YOLO_DATASET}/images/test\",\n    f\"{YOLO_DATASET}/labels/train\",\n    f\"{YOLO_DATASET}/labels/val\",\n    f\"{YOLO_DATASET}/labels/test\"\n]\n\nfor d in dirs:\n    os.makedirs(d, exist_ok=True)\n\nprint(\"YOLO folder structure created\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Class Mapping","metadata":{}},{"cell_type":"code","source":"# VisDrone classes\n# 0 -> pedestrian\n# 1 -> people\n# 3 -> car\n\nCLASS_MAP = {\n    0: 0,   # human\n    1: 0,   # human\n    3: 1    # car\n}\n\nCLASS_NAMES = {\n    0: \"Human\",\n    1: \"Car\"\n}\n\nprint(\"Class mapping ready\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Filter and remap YOLO labels","metadata":{}},{"cell_type":"code","source":"def filter_and_remap_labels(label_path, output_label_path):\n    \n    filtered_lines = []\n    \n    with open(label_path, \"r\") as f:\n        lines = f.readlines()\n    \n    for line in lines:\n        \n        parts = line.strip().split()\n        \n        if len(parts) != 5:\n            continue\n        \n        cls = int(parts[0])\n        \n        if cls not in CLASS_MAP:\n            continue\n        \n        mapped_cls = CLASS_MAP[cls]\n        \n        new_line = f\"{mapped_cls} {' '.join(parts[1:])}\"\n        \n        filtered_lines.append(new_line)\n    \n    with open(output_label_path, \"w\") as f:\n        f.write(\"\\n\".join(filtered_lines))\n    \n    return len(filtered_lines)","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Prepare train and val dataset","metadata":{}},{"cell_type":"code","source":"def process_split(img_dir, label_dir, split_name):\n    \n    image_output = f\"{YOLO_DATASET}/images/{split_name}\"\n    label_output = f\"{YOLO_DATASET}/labels/{split_name}\"\n    \n    total_objects = 0\n    \n    image_files = sorted(os.listdir(img_dir))\n    \n    for img_name in image_files:\n        \n        if not img_name.endswith(\".jpg\"):\n            continue\n        \n        img_path = os.path.join(img_dir, img_name)\n        \n        label_name = img_name.replace(\".jpg\", \".txt\")\n        label_path = os.path.join(label_dir, label_name)\n        \n        if not os.path.exists(label_path):\n            continue\n        \n        output_label_path = os.path.join(label_output, label_name)\n        \n        obj_count = filter_and_remap_labels(\n            label_path,\n            output_label_path\n        )\n        \n        if obj_count > 0:\n            \n            shutil.copy(img_path, os.path.join(image_output, img_name))\n            \n            total_objects += obj_count\n    \n    print(f\"{split_name} split done\")\n    print(f\"Total detected objects: {total_objects}\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Run Preproccesion","metadata":{}},{"cell_type":"code","source":"process_split(TRAIN_IMG_DIR, TRAIN_LABEL_DIR, \"train\")\nprocess_split(VAL_IMG_DIR, VAL_LABEL_DIR, \"val\")\n\nif os.path.exists(TEST_LABEL_DIR):\n    \n    process_split(TEST_IMG_DIR, TEST_LABEL_DIR, \"test\")\n    \n    print(\"Test split processed too\")\n\nelse:\n    \n    print(\"No test labels found\")\n    print(\"Skipping test split\")\n\nprint(\"Dataset preprocessing finished\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Create dataset YAML","metadata":{}},{"cell_type":"code","source":"dataset_yaml = {\n    \"path\": YOLO_DATASET,\n    \"train\": \"images/train\",\n    \"val\": \"images/val\",\n    \"test\": \"images/test\",\n    \"names\": {\n        0: \"Human\",\n        1: \"Car\"\n    }\n}\n\nyaml_path = f\"{WORKING_DIR}/dataset.yaml\"\n\nwith open(yaml_path, \"w\") as f:\n    yaml.dump(dataset_yaml, f)\n\nprint(\"dataset.yaml created\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Dataset statistics","metadata":{}},{"cell_type":"code","source":"label_dir = f\"{YOLO_DATASET}/labels/train\"\n\ncounter = Counter()\n\nfor file in os.listdir(label_dir):\n    \n    path = os.path.join(label_dir, file)\n    \n    with open(path, \"r\") as f:\n        lines = f.readlines()\n    \n    for line in lines:\n        cls = int(line.split()[0])\n        counter[cls] += 1\n\nprint(counter)","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Class distribution visualization","metadata":{}},{"cell_type":"code","source":"classes = [CLASS_NAMES[k] for k in counter.keys()]\ncounts = list(counter.values())\n\nplt.figure(figsize=(6,5))\nplt.bar(classes, counts)\n\nplt.title(\"Class Distribution\")\nplt.xlabel(\"Classes\")\nplt.ylabel(\"Count\")\n\nplt.savefig(f\"{WORKING_DIR}/class_distribution.png\")\n\nplt.show()\n\nprint(\"Class distribution saved\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Visualize annotated samples","metadata":{}},{"cell_type":"code","source":"sample_images = random.sample(\n    os.listdir(f\"{YOLO_DATASET}/images/train\"),\n    4\n)\n\nfig, axes = plt.subplots(2, 2, figsize=(12,12))\n\nfor ax, img_name in zip(axes.flatten(), sample_images):\n    \n    img_path = f\"{YOLO_DATASET}/images/train/{img_name}\"\n    label_path = f\"{YOLO_DATASET}/labels/train/{img_name.replace('.jpg','.txt')}\"\n    \n    image = cv2.imread(img_path)\n    image = cv2.cvtColor(image, cv2.COLOR_BGR2RGB)\n    \n    h, w = image.shape[:2]\n    \n    with open(label_path, \"r\") as f:\n        labels = f.readlines()\n    \n    for label in labels:\n        \n        cls, xc, yc, bw, bh = map(float, label.split())\n        \n        x1 = int((xc - bw/2) * w)\n        y1 = int((yc - bh/2) * h)\n        x2 = int((xc + bw/2) * w)\n        y2 = int((yc + bh/2) * h)\n        \n        color = (255,0,0) if int(cls)==0 else (0,255,0)\n        \n        cv2.rectangle(image, (x1,y1), (x2,y2), color, 2)\n        \n        cv2.putText(\n            image,\n            CLASS_NAMES[int(cls)],\n            (x1, y1-5),\n            cv2.FONT_HERSHEY_SIMPLEX,\n            0.5,\n            color,\n            2\n        )\n    \n    ax.imshow(image)\n    ax.axis(\"off\")\n\nplt.tight_layout()\n\nplt.savefig(f\"{WORKING_DIR}/dataset_samples.png\")\n\nplt.show()\n\nprint(\"Annotated dataset samples saved\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Load YOLO model","metadata":{}},{"cell_type":"code","source":"model = YOLO(\"yolov8s.pt\")\n\nprint(\"YOLOv8s loaded\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Train the model","metadata":{}},{"cell_type":"code","source":"results = model.train(\n    data=yaml_path,\n    epochs=100,\n    imgsz=640,\n    batch=16,\n    device=0,\n    workers=2,\n    patience=15,\n    optimizer=\"auto\",\n    amp=True,\n    project=WORKING_DIR,\n    name=\"human_car_detector\",\n    pretrained=True,\n    verbose=True,\n    cache=True,\n    exist_ok=True\n)\n\nprint(\"Training finished\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Evaluation Metrics","metadata":{}},{"cell_type":"code","source":"# loading the weights\nTRAIN_DIR = f\"{WORKING_DIR}/human_car_detector\"\nmodel_path = f\"{TRAIN_DIR}/weights/best.pt\"\n\